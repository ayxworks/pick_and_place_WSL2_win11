<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="$(arg name)">

  <xacro:arg name="name" default="ur"/>
  <xacro:arg name="use_sim" default="false"/>
  

  <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro"/>
  
  <xacro:include filename="$(find robotiq_description)/urdf/robotiq_2f_140_macro.urdf.xacro" />
  <xacro:include filename="$(find robotiq_description)/urdf/ur_to_robotiq_adapter.urdf.xacro" />
  
  <xacro:arg name="ur_type" default="ur10e"/>
  
  <!-- parameters -->
  <xacro:arg name="tf_prefix" default="" />
  <xacro:arg name="joint_limit_params" default="$(find setup_description)/config/$(arg ur_type)/joint_limits.yaml"/>
  <xacro:arg name="kinematics_params" default="$(find setup_description)/config/$(arg ur_type)/default_kinematics.yaml"/>
  <xacro:arg name="physical_params" default="$(find setup_description)/config/$(arg ur_type)/physical_parameters.yaml"/>
  <xacro:arg name="visual_params" default="$(find setup_description)/config/$(arg ur_type)/visual_parameters.yaml"/>
  <xacro:arg name="transmission_hw_interface" default=""/>
  <xacro:arg name="safety_limits" default="false"/>
  <xacro:arg name="safety_pos_margin" default="0.15"/>
  <xacro:arg name="safety_k_position" default="20"/>
  <xacro:arg name="robot_ip" default="172.16.7.75"/>
  <xacro:arg name="use_tool_communication" default="true"/>
  <xacro:arg name="use_fake_hardware" default="false"/>
  <xacro:arg name="gripper_com_port" default="/tmp/ttyUR"/>
  <xacro:arg name="script_filename" default=""/>
  <xacro:arg name="output_recipe_filename" default=""/>
  <xacro:arg name="input_recipe_filename" default=""/>
  <xacro:arg name="tool_voltage" default="24"/>
  <xacro:arg name="tool_baudrate" default="115200"/>
  <xacro:arg name="tool_parity" default="0" />
  <xacro:arg name="tool_stop_bits" default="1" />
  <xacro:arg name="tool_rx_idle_chars" default="1.5"/>
  <xacro:arg name="tool_tx_idle_chars" default="3.5" />
  <xacro:arg name="controllers_file" default="config/ur_controllers.yaml"/>
  <xacro:arg name="use_cam_flange_support" default="false"/>

  <!-- Gazebo Ignition plugin -->
  <xacro:property name="comparable_use_sim" value="$(arg use_sim)" />
  <xacro:if value="${comparable_use_sim}">
    <xacro:include filename="$(find setup_description)/gazebo/ur_robotiq.ignition_macro.xacro" />
    <xacro:ur_robotiq_ignition_macro 
      runtime_config_package="setup_description"
      path_to_yaml="$(arg controllers_file)"
      namespace="/"
      prefix="$(arg tf_prefix)"
    />
  </xacro:if>

  <!-- create link fixed to the "world" -->
  <link name="world" />
  
  <!-- arm -->
  <xacro:ur_robot
    name="$(arg name)"
    tf_prefix="$(arg tf_prefix)"
    parent="world"
    joint_limits_parameters_file="$(arg joint_limit_params)"
    kinematics_parameters_file="$(arg kinematics_params)"
    physical_parameters_file="$(arg physical_params)"
    visual_parameters_file="$(arg visual_params)"
    safety_limits="$(arg safety_limits)"
    safety_pos_margin="$(arg safety_pos_margin)"
    safety_k_position="$(arg safety_k_position)"
    sim_ignition="$(arg use_sim)"
    use_tool_communication="$(arg use_tool_communication)"
    robot_ip="$(arg robot_ip)"
    script_filename="$(arg script_filename)"
    output_recipe_filename="$(arg output_recipe_filename)"
    input_recipe_filename="$(arg input_recipe_filename)"
    tool_voltage="$(arg tool_voltage)"
    tool_baud_rate="$(arg tool_baudrate)"
    tool_parity="$(arg tool_parity)"
    tool_stop_bits="$(arg tool_stop_bits)"
    tool_rx_idle_chars="$(arg tool_rx_idle_chars)"
    tool_tx_idle_chars="$(arg tool_tx_idle_chars)"
  >
    <origin xyz="0 0 0" rpy="0 0 0" /> 
  </xacro:ur_robot>

  <!-- Camera flange support -->
  <xacro:property name="comparable_use_cam_flange_support" value="$(arg use_cam_flange_support)" />

  <xacro:if value="${comparable_use_cam_flange_support}">
    <xacro:property name="ur_to_robotiq_adapter_parent" value="cam_flange_ring_mounting" />
    <xacro:include filename="$(find cam_flange_support)/urdf/cam_flange_support_macro.urdf.xacro" />
    <xacro:cam_flange_support parent="tool0" >
      <origin xyz="0 0 0" rpy="0 0 ${pi}" /> 
    </xacro:cam_flange_support>
  </xacro:if>

  <xacro:unless value="${comparable_use_cam_flange_support}">
    <xacro:property name="ur_to_robotiq_adapter_parent" value="tool0" />
  </xacro:unless>

  <xacro:ur_to_robotiq prefix="" parent="${ur_to_robotiq_adapter_parent}" child="adapter_to_gripper"/>

  <!-- Robotiq 2F-140 Gripper connected to adapter -->
  <xacro:robotiq_gripper 
    name="RobotiqGripperHardwareInterface" 
    prefix="" 
    parent="adapter_to_gripper"
    sim_ignition="$(arg use_sim)"
    use_fake_hardware="$(arg use_fake_hardware)"
    com_port="$(arg gripper_com_port)">
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:robotiq_gripper>

  <!-- Virtual link for end effector at the fingertips -->
  <link name="ee_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.001"/>
      </geometry>
      <material name="transparent">
        <color rgba="0 0 0 0"/>
      </material>
    </visual>
  </link>

  <joint name="ee_joint" type="fixed">
    <parent link="tool0"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
  </joint>

</robot>